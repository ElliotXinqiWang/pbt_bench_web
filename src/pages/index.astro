---
import Layout from "../layouts/Layout.astro";

const CODE_URL = "https://anonymous.4open.science/r/pbt-bench-nips2026-60D2/README.md";
const PAPER_URL = "https://openreview.net/attachment?id=wota1ZN4By&name=pdf";
const DATA_URL = "https://huggingface.co/datasets/pbtbench-team/pbt-bench/tree/main";

const libraries = [
  {
    category: "Date & Time",
    libs: ["arrow", "pendulum", "dateutil", "babel", "icalendar"],
  },
  {
    category: "Data Structures",
    libs: ["sortedcontainers", "bidict", "portion", "cachetools", "toolz",
           "bintrees", "intervaltree", "multiset", "pyrsistent", "more_itertools", "diskcache"],
  },
  {
    category: "Serialization & Encoding",
    libs: ["msgpack", "cbor2", "pyasn1", "yaml", "construct", "tomlkit"],
  },
  {
    category: "Type Systems & Schemas",
    libs: ["attrs", "cattrs", "marshmallow", "jsonschema"],
  },
  {
    category: "Numerics & Math",
    libs: ["mpmath", "sympy", "galois", "pint"],
  },
  {
    category: "Graph & State Machines",
    libs: ["transitions", "networkx", "boltons"],
  },
  {
    category: "Parsing & Documents",
    libs: ["parso", "pyparsing", "pypdf", "html5lib", "lark", "pycparser", "openpyxl"],
  },
];

const results = [
  { model: "Sonnet 4.6",       pbtRecall: "83.4%", baseRecall: "76.7%", delta: "+6.7", perfect: "67.0%", highlight: true },
  { model: "Qwen 3.6 Plus",    pbtRecall: "78.0%", baseRecall: "53.5%", delta: "+24.5", perfect: "56.0%", highlight: false },
  { model: "GLM 5.1",          pbtRecall: "72.1%", baseRecall: "66.6%", delta: "+5.5",  perfect: "63.0%", highlight: false },
  { model: "Gemini 3 Flash",   pbtRecall: "62.8%", baseRecall: "56.2%", delta: "+6.6",  perfect: "37.0%", highlight: false },
  { model: "DeepSeek V3.2",    pbtRecall: "61.0%", baseRecall: "64.2%", delta: "−3.2",  perfect: "38.7%", highlight: false },
  { model: "Step 3.5 Flash",   pbtRecall: "58.1%", baseRecall: "37.8%", delta: "+20.3", perfect: "41.0%", highlight: false },
  { model: "Qwen 3.5-30B-A3B", pbtRecall: "54.3%", baseRecall: "31.4%", delta: "+22.9", perfect: "25.7%", highlight: false },
  { model: "Grok 4.1 Fast",    pbtRecall: "42.1%", baseRecall: "50.1%", delta: "−8.0",  perfect: "21.0%", highlight: false },
];
---

<Layout title="PBT-Bench — Benchmarking AI Agents on Property-Based Bug Discovery">

  <!-- NAV -->
  <nav>
    <div class="container nav-inner">
      <a href="/" class="logo">PBT-Bench</a>
      <div class="nav-links">
        <a href="#how-it-works">How It Works</a>
        <a href="#results">Results</a>
        <a href="#problems">Problems</a>
        <a href="#install">Get Started</a>
        <a href={PAPER_URL} class="btn-outline" target="_blank" rel="noopener noreferrer">
          Paper →
        </a>
        <a href={CODE_URL} class="btn-outline" target="_blank" rel="noopener noreferrer">
          Code →
        </a>
        <a href={DATA_URL} class="btn-outline" target="_blank" rel="noopener noreferrer">
          Dataset →
        </a>
      </div>
    </div>
  </nav>

  <main>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-glow"></div>
      <div class="container hero-content">
        <span class="badge">Research Benchmark</span>
        <h1>
          Benchmarking AI Agents on<br />
          <span class="accent">Property-Based Bug Discovery</span>
        </h1>
        <p class="hero-desc">
          PBT-Bench evaluates whether AI agents can discover hidden semantic bugs
          in real Python libraries using property-based testing with Hypothesis —
          guided solely by official API documentation, without any knowledge of the bugs.
        </p>
        <div class="stats-row">
          <div class="stat">
            <span class="stat-num">100</span>
            <span class="stat-label">Problems</span>
          </div>
          <div class="stat">
            <span class="stat-num">40</span>
            <span class="stat-label">Libraries</span>
          </div>
          <div class="stat">
            <span class="stat-num">365</span>
            <span class="stat-label">Injected Bugs</span>
          </div>
          <div class="stat">
            <span class="stat-num">L1–L3</span>
            <span class="stat-label">Difficulty Levels</span>
          </div>
          <div class="stat">
            <span class="stat-num">8</span>
            <span class="stat-label">Models Evaluated</span>
          </div>
        </div>
        <div class="hero-cta">
          <a href={PAPER_URL} class="btn-primary" target="_blank" rel="noopener noreferrer">
            Read Paper
          </a>
          <a href={CODE_URL} class="btn-secondary" target="_blank" rel="noopener noreferrer">
            Code
          </a>
          <a href={DATA_URL} class="btn-secondary" target="_blank" rel="noopener noreferrer">
            Dataset
          </a>
          <a href="#results" class="btn-secondary">Results ↓</a>
        </div>
      </div>
    </section>

    <!-- WHAT MAKES IT UNIQUE -->
    <section class="section" id="about">
      <div class="container">
        <h2 class="section-title">A different kind of benchmark</h2>
        <p class="section-desc">
          Most code benchmarks ask AI to fix a known bug or pass visible test gaps.
          PBT-Bench asks a harder question: can an agent <em>discover</em> bugs
          that no one told it about?
        </p>
        <div class="cards">
          <div class="card">
            <div class="card-icon">🔍</div>
            <h3>Bugs Invisible to Inspection</h3>
            <p>
              Every injected bug survives a 10-minute code review and passes all
              existing unit tests. Discovery requires systematic semantic reasoning,
              not grepping the source.
            </p>
          </div>
          <div class="card">
            <div class="card-icon">📚</div>
            <h3>Documentation as the Sole Oracle</h3>
            <p>
              Agents receive official API documentation only. Bugs hide in the gap
              between what the docs promise and what the implementation delivers.
              No bug descriptions, no hints.
            </p>
          </div>
          <div class="card">
            <div class="card-icon">⚡</div>
            <h3>Automated F→P Evaluation</h3>
            <p>
              The Fail-to-Pass criterion requires zero human judgment: a test must
              FAIL on the buggy library and PASS on the fixed version. Per-bug,
              per-function scoring. Fully reproducible.
            </p>
          </div>
          <div class="card">
            <div class="card-icon">🔒</div>
            <h3>Hidden Ground Truth</h3>
            <p>
              Reference property tests are never shown to agents. Any independent
              test that achieves F→P for a specific bug counts as a discovery —
              no pattern matching to a reference solution.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="section alt-bg" id="how-it-works">
      <div class="container">
        <h2 class="section-title">How It Works</h2>

        <div class="steps">
          <div class="step">
            <span class="step-num">01</span>
            <div class="step-content">
              <h3>Bug Injection</h3>
              <p>
                Semantic bugs are injected into real Python libraries via unified
                diff patches, at least two call-chain layers below the public API
                surface. Each bug violates a documented invariant, passes all
                existing unit tests, and has a precisely characterized trigger
                region — making it discoverable only through informed property testing.
              </p>
            </div>
          </div>
          <div class="step">
            <span class="step-num">02</span>
            <div class="step-content">
              <h3>Documentation as Oracle</h3>
              <p>
                The agent receives official API documentation as its only oracle.
                Its task is to infer semantic invariants from the docs —
                contracts the library promises to uphold — and design Hypothesis
                input strategies that concentrate probability mass on the trigger
                region. Source code is accessible but insufficient for localization.
              </p>
            </div>
          </div>
          <div class="step">
            <span class="step-num">03</span>
            <div class="step-content">
              <h3>Property Test Design</h3>
              <p>
                The agent writes Hypothesis <code>@given</code> property tests
                checking semantic contracts — roundtrip consistency,
                commutativity, idempotency, algebraic laws, cross-API protocol
                invariants, and more. The key challenge is crafting focused input
                strategies from documentation rather than defaulting to unconstrained
                random search.
              </p>
            </div>
          </div>
          <div class="step">
            <span class="step-num">04</span>
            <div class="step-content">
              <h3>F→P Evaluation</h3>
              <p>
                Each test function is evaluated independently against each
                <code>(buggy_lib, fixed_lib)</code> pair. A bug is found when
                at least one test FAILs on the buggy version and PASSes on the
                version with only that bug reversed. Bug-level recall and
                problem-level coverage are both reported.
              </p>
            </div>
          </div>
        </div>

        <!-- TWO TRACKS -->
        <div class="tracks">
          <h3 class="tracks-title">Two Evaluation Tracks</h3>
          <div class="track-cards">
            <div class="track-card">
              <span class="track-badge baseline">Baseline</span>
              <h4>Unconstrained Testing</h4>
              <p>
                The agent may use any testing approach. No framework is prescribed —
                unit tests, ad-hoc scripts, or property tests all count. This
                measures what's achievable with current best practices and serves
                as the comparison baseline.
              </p>
            </div>
            <div class="track-card">
              <span class="track-badge pbt">PBT</span>
              <h4>Property-Based Testing</h4>
              <p>
                The agent must use Hypothesis <code>@given</code> with custom
                input strategies and a compact property taxonomy (Roundtrip,
                Model-oracle, Invariant, Boundary). The scaffold eliminates
                framework-choice overhead and focuses effort on strategy design.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- RESULTS -->
    <section class="section" id="results">
      <div class="container">
        <h2 class="section-title">Results</h2>
        <p class="section-desc">
          4,800 agent trajectories across 8 models × 2 prompt modes × 3 independent runs.
          Bug-level recall averaged over three runs on all 100 problems.
        </p>

        <div class="results-table-wrap">
          <table class="results-table">
            <thead>
              <tr>
                <th>Model</th>
                <th>PBT Recall</th>
                <th>Baseline Recall</th>
                <th>Δ (pp)</th>
                <th>Perfect Rate (PBT)</th>
              </tr>
            </thead>
            <tbody>
              {results.map((r) => (
                <tr class={r.highlight ? "highlight-row" : ""}>
                  <td class="model-name">{r.model}</td>
                  <td class="recall-val">{r.pbtRecall}</td>
                  <td class="recall-val muted">{r.baseRecall}</td>
                  <td class={`delta-val ${r.delta.startsWith("+") ? "pos" : "neg"}`}>{r.delta}</td>
                  <td class="recall-val muted">{r.perfect}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="findings">
          <div class="finding">
            <span class="finding-num">01</span>
            <div>
              <h4>PBT scaffolding helps mid-capability models most</h4>
              <p>
                Recall gains (Δ = PBT − Baseline) range from
                <strong>+24.5 pp</strong> (Qwen 3.6 Plus) and <strong>+22.9 pp</strong> (Qwen 3.5-30B-A3B)
                down to <strong>−8.0 pp</strong> (Grok 4.1 Fast).
                For the four models with the largest gaps, |Δ| exceeds the sum of their 95% bootstrap CIs,
                so those signs are statistically robust.
                The pattern is consistent with the PBT prompt substituting for a capability weaker models
                lack — not complementing a skill stronger models already carry.
              </p>
            </div>
          </div>
          <div class="finding">
            <span class="finding-num">02</span>
            <div>
              <h4>Coverage and full recall diverge; the benchmark is not saturated</h4>
              <p>
                The top cell (Sonnet 4.6 Baseline) achieves <strong>98.0% problem coverage</strong>
                but only <strong>43.0% perfect recall</strong> — it frequently finds one bug but misses
                co-located bugs. Switching to PBT trades coverage (92.7%) for a large gain in perfect recall (67.0%),
                consistent with its instruction to write multiple focused tests per bug.
                No cell exceeds 70% perfect rate.
              </p>
            </div>
          </div>
          <div class="finding">
            <span class="finding-num">03</span>
            <div>
              <h4>Ensemble upper bound: 99.5% with 16 cells</h4>
              <p>
                The best single cell (Sonnet 4.6 PBT) reliably covers <strong>317 of 365 bugs (86.8%)</strong>.
                Adding Sonnet 4.6 Baseline lifts union coverage to <strong>95.1%</strong>;
                the full 16-cell ensemble reaches <strong>99.5%</strong>.
                Within-model mode complementarity (PBT + Baseline, same architecture) accounts for
                <strong>65% of ensemble headroom</strong> — suggesting the two modes elicit
                categorically different testing strategies even within a single model.
                Two L3 bugs remain out of reach of any cell within the 200-example budget.
              </p>
            </div>
          </div>
          <div class="finding">
            <span class="finding-num">04</span>
            <div>
              <h4>L1–L3 labels track empirical hardness</h4>
              <p>
                Averaged across all eight models, mean recall descends monotonically:
                <strong>L1 66% → L2 60% → L3 51%</strong>.
                This ordering holds in 15 of 16 cells.
                For weaker models, the PBT benefit itself decreases with difficulty:
                Qwen 3.5-30B-A3B gains +35.2 / +25.4 / +14.8 pp on L1/L2/L3,
                suggesting the scaffold substitutes for constraint-reasoning on easy bugs
                but cannot close the gap on L3 protocol violations.
              </p>
            </div>
          </div>
          <div class="finding">
            <span class="finding-num">05</span>
            <div>
              <h4>Failure modes are categorically different between tracks</h4>
              <p>
                Over 20 sampled failures per cell, Baseline failures concentrate on
                <strong>Incorrect Assertion (59%)</strong> and <strong>Overly Concrete Test (32%)</strong> —
                correct-looking tests aimed at the wrong invariant.
                PBT failures shift to search pathologies:
                <strong><code>assume()</code> misuse (31%)</strong>, where the agent excludes the bug's
                trigger region via over-filtering, and <strong>Wrong Strategy Range (31%)</strong>,
                where the input distribution misses the narrow trigger.
                Both failure modes are prompt-actionable without architectural changes.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PROBLEM SET -->
    <section class="section alt-bg" id="problems">
      <div class="container">
        <h2 class="section-title">Problem Set</h2>
        <p class="section-desc">
          100 problems across 40 real Python libraries in 7 domains. Each problem contains
          one or more injected semantic bugs (365 total, mean 3.65 per problem)
          organized into three difficulty levels.
        </p>

        <div class="lib-grid">
          {libraries.map((cat) => (
            <div class="lib-category">
              <h4>{cat.category}</h4>
              <div class="lib-tags">
                {cat.libs.map((lib) => (
                  <span>{lib}</span>
                ))}
              </div>
            </div>
          ))}
        </div>

        <h3 class="subsection-title">Difficulty Levels</h3>
        <div class="diff-table-wrap">
          <table class="diff-table">
            <thead>
              <tr>
                <th>Level</th>
                <th>Count</th>
                <th>Description</th>
                <th>Trigger requirement</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><span class="level l1">L1</span></td>
                <td class="count-val">87</td>
                <td>Single-constraint bugs. Default Hypothesis strategies suffice or a single doc-derived constraint is needed.</td>
                <td>One input range, size class, or structural property</td>
              </tr>
              <tr>
                <td><span class="level l2">L2</span></td>
                <td class="count-val">184</td>
                <td>Multi-constraint triggers requiring simultaneous satisfaction of several documentation-derived conditions.</td>
                <td>Specific value range <em>and</em> structural constraints <em>and</em> operation ordering</td>
              </tr>
              <tr>
                <td><span class="level l3">L3</span></td>
                <td class="count-val">94</td>
                <td>Cross-function or cross-operation protocol violations requiring stateful or metamorphic tests.</td>
                <td>Invariant spans multiple API calls; requires sequences or metamorphic checks</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="problem-note">
          Each problem directory contains official API documentation (the agent's only oracle),
          existing unit tests (all passing on the buggy library), reversible per-bug patches,
          and hidden ground-truth property tests used only for infrastructure validation.
          A three-stage QA pipeline — automated checks, reference-model gate, and manual adversarial
          review — ensures every accepted bug is semantically meaningful, stealthy, and PBT-testable.
        </div>
      </div>
    </section>

    <!-- INSTALLATION -->
    <section class="section" id="install">
      <div class="container">
        <h2 class="section-title">Get Started</h2>

        <div class="install-requirements">
          <p class="req-title">Requirements</p>
          <ul>
            <li>Python 3.12</li>
            <li>
              <a href="https://github.com/astral-sh/uv" target="_blank" rel="noopener noreferrer">uv</a>
              package manager
            </li>
            <li>Docker (for isolated evaluation containers)</li>
            <li>An LLM API key — Anthropic, OpenRouter, or compatible</li>
          </ul>
        </div>

        <div class="install-steps">
          <div class="install-step">
            <p class="step-label">1 &mdash; Install</p>
            <pre class="code-block"><code>cd pbt-bench

<span class="cm"># Create virtual environment and install dependencies</span>
uv venv .venv --python 3.12
uv pip install -r requirements.txt
uv pip install \
    vendor/software-agent-sdk/openhands-sdk \
    vendor/software-agent-sdk/openhands-tools \
    vendor/software-agent-sdk/openhands-workspace \
    vendor/software-agent-sdk/openhands-agent-server</code></pre>
          </div>

          <div class="install-step">
            <p class="step-label">2 &mdash; Configure your LLM</p>
            <pre class="code-block"><code>cp llm_configs/llm_config_example.json eval/llm_config.json
<span class="cm"># then edit eval/llm_config.json and fill in your API key</span></code></pre>
            <p class="install-note">
              Supported: Anthropic, OpenRouter, or any OpenAI-compatible endpoint.
              See <code>llm_configs/</code> for format examples.
            </p>
          </div>

          <div class="install-step">
            <p class="step-label">3 &mdash; Run</p>
            <pre class="code-block"><code><span class="cm"># PBT mode — first 5 problems, 40 agent iterations each</span>
.venv/bin/python3 eval/run_pbt.py eval/llm_config.json \
    --n-limit 5 --max-iterations 40 --note my_run

<span class="cm"># Baseline mode</span>
.venv/bin/python3 eval/run_baseline.py eval/llm_config.json \
    --max-iterations 50 --note my_run

<span class="cm"># Or run both tracks via the shell script</span>
bash scripts/run_eval.sh</code></pre>
          </div>
        </div>

        <div class="output-note">
          <p class="output-note-title">Output</p>
          <p>
            Results stream to <code>experiments/eval_outputs/&lt;mode&gt;/&lt;model&gt;_&lt;note&gt;/&lt;timestamp&gt;/</code>
            as JSONL — crash-safe and resumable. Each run directory contains
            <code>output.jsonl</code> (per-problem results), <code>summary.json</code> (aggregate metrics),
            and <code>_workspaces/&lt;ID&gt;/pbt_test.py</code> (the agent's test file).
            Use <code>eval/display.py</code> to view live progress during a run.
          </p>
        </div>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer>
    <div class="container footer-inner">
      <div class="footer-left">
        <span class="footer-logo">PBT-Bench</span>
      </div>
      <div class="footer-right">
        <a href={PAPER_URL} target="_blank" rel="noopener noreferrer">Paper ↗</a>
        <a href={DATA_URL} target="_blank" rel="noopener noreferrer">Dataset ↗</a>
        <a href={CODE_URL} target="_blank" rel="noopener noreferrer">Code ↗</a>
      </div>
    </div>
    <div class="container blind-note">
      Author information, institution affiliations, and repository ownership are withheld
      for double-blind peer review. Code and data are served via anonymized mirrors.
    </div>
  </footer>

</Layout>

<style>
